# Required
OPENAI_API_KEY=sk-...

# Optional but strongly recommended (boosts GitHub rate limit 60->5000/hr)
GITHUB_TOKEN=ghp_...

# Public URL where this is hosted. Used for share links.
# In Railway, set this to your custom domain or *.up.railway.app URL.
BASE_URL=https://urcooked.lol

# Override the OpenAI model if needed. gpt-5.4-mini is the default.
# OPENAI_MODEL=gpt-5.4-mini

# Port. Railway injects this automatically. Locally, use 3000.
PORT=3000

# Where the SQLite file lives. Default: ./db
# In Docker/Railway this should be the mounted volume path.
DB_DIR=./db
